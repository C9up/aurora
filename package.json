{
	"name": "@c9up/aurora",
	"version": "0.1.19",
	"description": "Aurora — reactive UI runtime for the Ream framework. Tagged-template DOM, signal-based state, isomorphic SSR + hydration, zero build step.",
	"license": "MIT",
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		},
		"./provider": {
			"types": "./src/AuroraProvider.ts",
			"import": "./src/AuroraProvider.ts"
		},
		"./services/main": {
			"types": "./src/services/main.ts",
			"import": "./src/services/main.ts"
		},
		"./relay": {
			"types": "./src/relay.ts",
			"import": "./src/relay.ts"
		},
		"./ssr": {
			"types": "./src/ssr.ts",
			"import": "./src/ssr.ts"
		},
		"./hydrate": {
			"types": "./src/hydrate.ts",
			"import": "./src/hydrate.ts"
		},
		"./server": {
			"types": "./src/server.ts",
			"import": "./src/server.ts"
		},
		"./rpc": {
			"types": "./src/rpc.ts",
			"import": "./src/rpc.ts"
		}
	},
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"lint": "biome check src/",
		"test:coverage": "vitest run --coverage",
		"test:browser": "vitest run -c vitest.browser.config.ts"
	},
	"peerDependencies": {
		"@c9up/comet": "^0.1.0",
		"@c9up/ream": "^0.1.0"
	},
	"peerDependenciesMeta": {
		"@c9up/comet": {
			"optional": true
		},
		"@c9up/ream": {
			"optional": true
		}
	},
	"devDependencies": {
		"@c9up/comet": "^0.1.0",
		"@types/node": "^22.19.15",
		"@vitest/browser": "4.1.6",
		"@vitest/browser-playwright": "^4.1.9",
		"happy-dom": "^15.11.7",
		"playwright": "^1.61.1",
		"typescript": "^6.0.2",
		"vitest": "^4.1.2"
	},
	"files": [
		"LICENSE",
		"README.md",
		"dist",
		"src"
	],
	"publishConfig": {
		"main": "./dist/index.js",
		"types": "./dist/index.d.ts",
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"import": "./dist/index.js"
			},
			"./provider": {
				"types": "./dist/AuroraProvider.d.ts",
				"import": "./dist/AuroraProvider.js"
			},
			"./services/main": {
				"types": "./dist/services/main.d.ts",
				"import": "./dist/services/main.js"
			},
			"./relay": {
				"types": "./dist/relay.d.ts",
				"import": "./dist/relay.js"
			},
			"./ssr": {
				"types": "./dist/ssr.d.ts",
				"import": "./dist/ssr.js"
			},
			"./hydrate": {
				"types": "./dist/hydrate.d.ts",
				"import": "./dist/hydrate.js"
			},
			"./server": {
				"types": "./dist/server.d.ts",
				"import": "./dist/server.js"
			},
			"./rpc": {
				"types": "./dist/rpc.d.ts",
				"import": "./dist/rpc.js"
			}
		},
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/C9up/aurora.git"
	}
}
