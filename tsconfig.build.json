{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"noEmit": false,
		"module": "ES2022",
		"moduleResolution": "Bundler",
		"target": "ES2022",
		"lib": ["ES2023", "DOM", "DOM.Iterable"],
		"outDir": "dist",
		"rootDir": "src",
		"declaration": true,
		"declarationMap": false,
		"sourceMap": false,
		"emitDecoratorMetadata": false,
		"experimentalDecorators": false
	},
	"include": ["src"],
	"exclude": ["src/**/*.test.ts", "tests", "node_modules", "dist"]
}
